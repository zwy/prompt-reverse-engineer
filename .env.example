# LLM Provider 配置
# 可选值: openai / perplexity / ollama / grok
LLM_PROVIDER=openai

# 模型名称（留空则使用各 provider 默认模型）
# openai 默认:     gpt-4o-mini
# perplexity 默认: google/gemini-3-flash-preview
# ollama 默认:     qwen2.5:7b
# grok 默认:       grok-4-1-fast-non-reasoning
LLM_MODEL=

# API Key（留空则自动读取对应 provider 的专属环境变量）
LLM_API_KEY=

# 自定义 Base URL（可选，用于代理或自托管服务）
LLM_BASE_URL=

# --- 各 Provider 专属 Key（二选一方式）---
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
